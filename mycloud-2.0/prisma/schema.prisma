// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum UserSortPreference {
    name
    uploadedAt
}

model User {
    id       Int    @id @default(autoincrement())
    email    String @unique
    password String
    maxStorage  BigInt //In bytes
    takenSpace  BigInt @default(0) //In bytes
    files   File[]
    folders Folder[]
    tokens ResetTokens[]
    emailVerified     Boolean  @default(false)
    verifyToken String @unique
    sortPreference UserSortPreference @default(uploadedAt)
}

model File {
    id      Int @id @default(autoincrement())
    name    String
    user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId  Int
    type    String
    size    BigInt //In bytes
    uploadedAt    DateTime
    folder Folder? @relation( fields: [folderId], references: [id])
    folderId Int?
}

model ResetTokens {
    id Int @id @default(autoincrement())
    token String @unique
    expires DateTime
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId Int
}

model Folder {
    id Int @id @default(autoincrement())
    name String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId  Int
    createdAt DateTime

    folderId  Int?
    parent    Folder?  @relation("FolderChildren", fields: [folderId], references: [id], onDelete: Cascade)
    children  Folder[] @relation("FolderChildren")
    files   File[]
}
